<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.service.telegramstream" name="Telegram Stream" version="1.0.1" provider-name="Jules">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
    <import addon="script.module.requests" version="2.25.1"/>
  </requires>
  <extension point="xbmc.service" library="service.py" start="startup"/>
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Stream videos from Telegram to Kodi</summary>
    <description lang="en_GB">Automatically plays videos sent to a Telegram bot on Kodi. Note: Standard Telegram files are limited to 20MB by the Bot API.</description>
    <language>en</language>
    <platform>all</platform>
    <license>GPL-2.0-or-later</license>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
  </extension>
</addon>
