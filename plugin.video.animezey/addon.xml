<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.animezey" name="AnimeZeY" version="1.0.0" provider-name="Jules">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="pt_BR">Addon para o site AnimeZeY</summary>
        <description lang="pt_BR">Acesse o vasto acervo de animes, filmes e desenhos do AnimeZeY diretamente no seu Kodi. Otimizado para navegação rápida e compatível com Android e MI TV Box.</description>
        <disclaimer lang="pt_BR">Este addon apenas indexa conteúdo disponível publicamente no site AnimeZeY.</disclaimer>
        <language>pt</language>
        <platform>all</platform>
        <license>GPL-2.0-only</license>
        <forum></forum>
        <website>https://1.animezey23112022.workers.dev/</website>
        <source>https://github.com/</source>
        <assets>
            <icon>icon.jpg</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
